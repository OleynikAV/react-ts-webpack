{
  "main": "src/index.tsx",
  "name": "react-starter-split-webpack-5-ts",
  "config": {
    "dev": "--config __webpack__/dev.config.js",
    "prod": "--config __webpack__/prod.config.js"
  },
  "version": "1.0.0",
  "description": "React Starter App using TS",
  "homepage": "https://github.com/OleynikAV/react-ts-webpack",
  "author": "Andrey Oleynik",
  "scripts": {
    "webpack-config-dev": "nodemon --watch \"./__webpack__/*\" --exec npm run start-dev",
    "webpack-config-prod": "nodemon --watch \"./__webpack__/*\" --exec npm run start-prod",
    "start-dev": "cross-env-shell webpack serve ${npm_package_config_dev}",
    "start-prod": "cross-env-shell webpack serve ${npm_package_config_prod}",
    "build-dev": "cross-env-shell webpack ${npm_package_config_dev}",
    "build-prod": "cross-env-shell webpack ${npm_package_config_prod} --stats-children",
    "clean": "rd /s /q build",
    "lint": "eslint src --ext .js --ext .ts --ext .jsx --ext .tsx",
    "lint-fix": "eslint src --ext .js --ext .ts --ext .jsx --ext .tsx --fix",
    "test": "cross-env jest --config __jest__/jest.config.js",
    "test-watch": "jest --watch --config __jest__/jest.config.js",
    "test-coverage": "jest --coverage --config __jest__/jest.config.js"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^9.39.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "favicons": "~7.3.0",
    "favicons-webpack-plugin": "^6.0.1",
    "filemanager-webpack-plugin": "^10.0.1",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "image-minimizer-webpack-plugin": "^5.0.0",
    "imagemin": "^9.0.1",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-svgo": "^12.0.0",
    "jest": "^30.4.2",
    "jest-css-modules-transform": "^4.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "mini-css-extract-plugin": "^2.10.2",
    "nodemon": "^3.1.14",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.3.2",
    "react-refresh": "^0.18.0",
    "sass-loader": "^17.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^5.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@reduxjs/toolkit": "^2.12.0",
    "classnames": "^2.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1"
  },
  "allowScripts": {
    "gifsicle@5.3.0": true,
    "@parcel/watcher@2.6.0": true,
    "core-js-pure@3.49.0": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
