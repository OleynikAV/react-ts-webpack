# Скопируйте этот файл в .env.local и подставьте свои значения.
# .env.local НЕ коммитится (см. .gitignore).

# Firebase (публичная клиентская конфигурация — не является секретом,
# но выносим в env для конфигурируемости под окружения)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJ_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MSG_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# TMDB — НАСТОЯЩИЙ секрет. В клиентском бандле он всё равно виден пользователю,
# поэтому для продакшена запросы к TMDB лучше проксировать через свой backend.
REACT_APP_TMDB_API_KEY=
REACT_APP_TMDB_API_URL=
